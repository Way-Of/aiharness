{
  "project": "aiharness",
  "namespace": "AIH",
  "version_files": [
    {
      "path": "manifest.json",
      "fields": ["version"],
      "type": "json",
      "bump_order": 1
    },
    {
      "path": "config-manifest/base_manifest.yaml",
      "fields": ["manifest_version"],
      "type": "yaml",
      "bump_order": 2
    },
    {
      "path": "install.ts",
      "fields": ["version string"],
      "type": "regex",
      "pattern": "const VERSION = \"(\\d+\\.\\d+\\.\\d+)\"",
      "bump_order": 3
    },
    {
      "path": "docs/fixes.md",
      "fields": ["version header"],
      "type": "markdown",
      "bump_order": 4
    },
    {
      "path": "README.md",
      "fields": ["version references"],
      "type": "markdown",
      "bump_order": 5
    }
  ],
  "bump_order": ["manifest.json", "base_manifest.yaml", "install.ts", "docs/fixes.md", "README.md"]
}
